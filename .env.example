# ─── Valora Group — environment configuration ───────────────────────────────
# Copy this file to `.env.local` and fill in the values. None are required for
# the site to build and render; they enable the live assistant and the contact
# form delivery.

# Public site URL (used for metadata, canonical URLs, sitemap, Open Graph).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── AI assistant (Anthropic / Claude) ──────────────────────────────────────
# Get a key at https://console.anthropic.com. Without it, the chat widget shows
# an "assistant isn't configured yet" message.
ANTHROPIC_API_KEY=
# Optional. Defaults to claude-sonnet-4-6 (fast + cost-efficient for a public
# widget). Use claude-opus-4-8 for maximum quality.
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Contact form email delivery (Resend) ───────────────────────────────────
# Get a key at https://resend.com. Without these, contact submissions are
# logged server-side (not emailed) but the form still succeeds.
RESEND_API_KEY=
# Where inquiries are sent.
CONTACT_TO_EMAIL=you@yourdomain.com
# The "From" address. Must be on a domain you've verified in Resend.
# For quick testing you can use: Valora Group <onboarding@resend.dev>
CONTACT_FROM_EMAIL=Valora Group <hello@valoragroup.ai>

# ── Bot protection (Cloudflare Turnstile) ──────────────────────────────────
# Free at https://dash.cloudflare.com/?to=/:account/turnstile. Without these,
# the contact form falls back to a honeypot only (no CAPTCHA shown).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Global rate limiting (Upstash Redis) ───────────────────────────────────
# Free at https://upstash.com. Without these, rate limiting is per-instance
# in-memory only (resets per cold start, not shared across instances).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Optional global cap on AI chat requests per day (cost guardrail). Default 2000.
CHAT_DAILY_LIMIT=2000
